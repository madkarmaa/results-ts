{
    "name": "results-ts",
    "version": "3.0.0",
    "description": "Rust's Result and Option types, for TypeScript",
    "devDependencies": {
        "@commitlint/cli": "^21.0.1",
        "@commitlint/config-conventional": "^21.0.1",
        "@types/bun": "^1.3.14",
        "husky": "^9.1.7",
        "prettier": "3.8.3",
        "tsdown": "^0.22.1",
        "typescript": "^6.0.3",
        "vitest": "^4.1.7"
    },
    "type": "module",
    "main": "./dist/index.js",
    "exports": {
        ".": {
            "default": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "prepare": "husky",
        "build": "tsdown",
        "dev": "tsdown --watch",
        "test": "vitest run",
        "test:dev": "vitest watch",
        "typecheck": "tsc --noEmit",
        "typecheck:dev": "tsc --noEmit --watch",
        "format": "prettier --write --ignore-unknown .",
        "tags": "git push origin --tags && git push",
        "patch": "bun pm version patch && bun run tags",
        "minor": "bun pm version minor && bun run tags",
        "major": "bun pm version major && bun run tags"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/madkarmaa/results-ts.git"
    },
    "license": "MIT",
    "keywords": [
        "javascript",
        "javascript-library",
        "js",
        "js-lib",
        "library",
        "rust",
        "rust-option",
        "rust-result",
        "rust-typescript",
        "ts",
        "ts-lib",
        "typescript",
        "typescript-library",
        "typescript-rust"
    ]
}
